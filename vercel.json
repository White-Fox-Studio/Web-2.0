{
  "version": 2,
  "builds": [
    {
      "src": "api/config.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/catalog.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/order.js",
      "use": "@vercel/node"
    },
    {
      "src": "crm.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "v1.0_2026-04-20.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "FOOTER_v1.0_2026-04-20.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.ico",
      "use": "@vercel/static"
    },
    {
      "src": "preview_cat_transparent.gif",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/config",
      "dest": "/api/config.js"
    },
    {
      "src": "/api/catalog",
      "dest": "/api/catalog.js"
    },
    {
      "src": "/api/order",
      "dest": "/api/order.js"
    },
    {
      "src": "/api/crm",
      "dest": "/crm.js"
    },
    {
      "src": "/v1.0_2026-04-20.pdf",
      "dest": "/v1.0_2026-04-20.pdf"
    },
    {
      "src": "/FOOTER_v1.0_2026-04-20.pdf",
      "dest": "/FOOTER_v1.0_2026-04-20.pdf"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/preview_cat_transparent.gif",
      "dest": "/preview_cat_transparent.gif"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
